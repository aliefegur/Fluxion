---
Checks: >
  -*,
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  portability-*,

  readability-identifier-naming,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-nodiscard,
  modernize-use-default-member-init,

  -bugprone-easily-swappable-parameters

WarningsAsErrors: >
  clang-analyzer-*,
  bugprone-*

HeaderFilterRegex: '^(?!.*ThirdParty/).*'

FormatStyle: file

CheckOptions:
  - key: readability-identifier-naming.ClassCase
    value: CamelCase

  - key: readability-identifier-naming.StructCase
    value: CamelCase

  - key: readability-identifier-naming.FunctionCase
    value: CamelCase

  - key: readability-identifier-naming.VariableCase
    value: camelBack

  # Public class members
  - key: readability-identifier-naming.ClassMemberCase
    value: CamelCase

  # Private class members
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: m_

  - key: readability-identifier-naming.PrivateMemberCase
    value: CamelCase

  # Static members
  - key: readability-identifier-naming.ClassStaticMemberPrefix
    value: s_
  - key: readability-identifier-naming.ClassStaticMemberCase
    value: CamelCase
  - key: readability-identifier-naming.StaticVariablePrefix
    value: s_
  - key: readability-identifier-naming.VariableIgnoredRegexp
    value: '^s_.*'

  # Struct members
  - key: readability-identifier-naming.StructMemberCase
    value: CamelCase
  - key: readability-identifier-naming.PrivateStructMemberCase
    value: CamelCase

  - key: readability-identifier-naming.ConstantCase
    value: UPPER_CASE
